# Supabase — safe to expose to browser (anon key only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe — safe to expose to browser (publishable key only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App URL (used in Stripe redirect URLs)
VITE_APP_URL=http://localhost:5173

# Server-side only — NEVER prefix with VITE_
# These stay in Vercel project settings, never in committed .env files
# ANTHROPIC_API_KEY=sk-ant-...
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
